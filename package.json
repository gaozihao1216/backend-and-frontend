  },
  "devDependencies": {
    "@types/matter-js": "^0.20.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^7.0.0"
  }
