# Backend database mode
# Omit UGC_DATABASE_MODE (or any value other than "jdbc") for default in-memory storage.
# UGC_DATABASE_MODE=jdbc

# PostgreSQL (used when UGC_DATABASE_MODE=jdbc)
UGC_DATABASE_URL=jdbc:postgresql://localhost:5432/ugc_level_platform
UGC_DATABASE_USERNAME=postgres
UGC_DATABASE_PASSWORD=postgres
UGC_DATABASE_DRIVER=org.postgresql.Driver
UGC_DATABASE_SCHEMA=public
